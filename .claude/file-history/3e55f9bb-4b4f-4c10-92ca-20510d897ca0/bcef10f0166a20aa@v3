#!/usr/bin/env python3
"""
Generate browsable HTML reports from evaluation run data.

Standalone script — no imports from the homr repo.

Four levels of interlinked HTML:
  1. All runs index  — runs/index.html
  2. Run index       — runs/<effort>/<hash>_avg<ser>/index.html
  3. Piece index     — .../piece-NNN/index.html
  4. Page index      — .../piece-NNN/page-NN/index.html

Also generates:
  - spot/index.html (all spot checks)
  - spot/piece-NNN/<effort>/<hash>_ser<ser>/index.html

Usage:
    python scripts/generate_html.py
    python scripts/generate_html.py --run runs/effort/hash_avg37
"""

