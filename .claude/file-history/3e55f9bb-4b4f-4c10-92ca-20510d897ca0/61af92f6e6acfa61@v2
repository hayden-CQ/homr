#!/usr/bin/env python3
"""Convert fp16 ONNX models to fp32 for CPU inference.

Usage:
    python scripts/convert_fp16_to_fp32.py encoder_fp16.onnx encoder.onnx
    python scripts/convert_fp16_to_fp32.py decoder_fp16.onnx decoder.onnx
"""

import sys
from pathlib import Path

import numpy as np
import onnx
from onnx import TensorProto, numpy_helper


def convert_subgraph(graph):
    """Recursively convert all fp16 -> fp32 in a graph and its subgraphs."""
    for tensor in graph.initializer:
        if tensor.data_type == TensorProto.FLOAT16:
            arr = numpy_helper.to_array(tensor).astype(np.float32)
            new_tensor = numpy_helper.from_array(arr, tensor.name)
            tensor.CopyFrom(new_tensor)

    for inp in list(graph.input) + list(graph.output):
        if inp.type.tensor_type.elem_type == TensorProto.FLOAT16:
            inp.type.tensor_type.elem_type = TensorProto.FLOAT

    for vi in graph.value_info:
        if vi.type.tensor_type.elem_type == TensorProto.FLOAT16:
            vi.type.tensor_type.elem_type = TensorProto.FLOAT

    for node in graph.node:
        for attr in node.attribute:
            if attr.name == "to" and attr.i == TensorProto.FLOAT16:
                attr.i = TensorProto.FLOAT
            if attr.g and attr.g.node:
                convert_subgraph(attr.g)
            for sub_g in attr.graphs:
                convert_subgraph(sub_g)


def main():
    if len(sys.argv) != 3:
        print(f"Usage: {sys.argv[0]} <input_fp16.onnx> <output_fp32.onnx>")
        sys.exit(1)

    input_path = Path(sys.argv[1])
    output_path = Path(sys.argv[2])

    if not input_path.exists():
        print(f"ERROR: {input_path} not found", file=sys.stderr)
        sys.exit(1)

    print(f"Loading {input_path} ...")
    model = onnx.load(str(input_path))

    print("Converting fp16 -> fp32 ...")
    convert_subgraph(model.graph)

    print(f"Saving {output_path} ...")
    onnx.save(model, str(output_path))

    in_mb = input_path.stat().st_size / 1024 / 1024
    out_mb = output_path.stat().st_size / 1024 / 1024
    print(f"Done. {in_mb:.1f} MB -> {out_mb:.1f} MB")


if __name__ == "__main__":
    main()
