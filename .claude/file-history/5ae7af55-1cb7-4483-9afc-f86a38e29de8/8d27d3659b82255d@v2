#!/usr/bin/env python3
"""Run v2 diagnosis on any eval run directory.

Usage: python test_v2_any_run.py <run_dir> [<label>]

Example:
  python test_v2_any_run.py ../runs/main/f0c0df3_avg48 main
  python test_v2_any_run.py ../runs/historical-eval-20260314/29e394f_avg36 branch
"""

import json
import sys
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(SCRIPT_DIR))

from run_evaluation import diagnose_piece

DATA_DIR = SCRIPT_DIR.parent
manifest = json.load(open(DATA_DIR / "manifest.json"))

if len(sys.argv) < 2:
    print(__doc__)
    sys.exit(1)

run_dir = Path(sys.argv[1]).resolve()
label = sys.argv[2] if len(sys.argv) > 2 else run_dir.name

# Try to load v1 results.json from the run dir for comparison
v1_results = {}
results_json = run_dir / "results.json"
if results_json.exists():
    v1_data = json.load(open(results_json))
    v1_results = v1_data.get("pieces", {})

header = (
    f"{'Piece':<12} "
    + (f"{'v1%':>4} " if v1_results else "")
    + f"{'v2%':>4} "
    f"{'Notes':>6} {'Errs':>5} {'PerfM':>6} "
    f"{'Key':>5} {'Time':>5} {'Clef':>5} "
    f"{'Slur':>6} {'Grace':>6} {'Artic':>6} {'Rep':>5}"
)
print(f"Run: {label} ({run_dir})")
print(header)
print("-" * len(header))

total_v1 = 0
total_v2 = 0
total_notes = 0
total_errors = 0
count = 0
big_diff = []

for piece_id in sorted(manifest.keys()):
    gt_path = DATA_DIR / "sources" / f"{piece_id}.xml"
    out_dir = run_dir / piece_id
    if not gt_path.exists() or not out_dir.exists():
        continue

    out_files = sorted(out_dir.glob("*.musicxml"))
    if not out_files:
        continue

    v1_ser = v1_results.get(piece_id, {}).get("ser", None)

    result = diagnose_piece(gt_path, out_files)
    if result is None:
        v1_str = f"{v1_ser:>3}% " if v1_ser is not None else ""
        print(f"{piece_id:<12} {v1_str}SKIP")
        continue

    diag, _ = result
    v2_ser = diag.note_ser.pct

    def acc(m):
        if m.total == 0:
            return "-"
        return f"{m.errors}/{m.total}"

    v1_str = f"{v1_ser:>3}% " if v1_ser is not None else ""
    print(
        f"{piece_id:<12} {v1_str}{v2_ser:>3}% "
        f"{diag.note_ser.total:>6} {diag.note_ser.errors:>5} "
        f"{diag.perfect_measures:>3}/{diag.total_measures_compared:<3} "
        f"{acc(diag.key_accuracy):>5} {acc(diag.time_accuracy):>5} "
        f"{acc(diag.clef_accuracy):>5} {acc(diag.slur_accuracy):>6} "
        f"{acc(diag.grace_accuracy):>6} {acc(diag.articulation_accuracy):>6} "
        f"{acc(diag.repeat_accuracy):>5}"
    )

    if v1_ser is not None:
        if abs(v1_ser - v2_ser) >= 10:
            big_diff.append((piece_id, v1_ser, v2_ser))
        total_v1 += v1_ser

    total_v2 += v2_ser
    total_notes += diag.note_ser.total
    total_errors += diag.note_ser.errors
    count += 1

print("-" * len(header))
if count:
    avg_line = f"{'AVERAGE':<12} "
    if v1_results:
        avg_line += f"{total_v1/count:>3.0f}% "
    avg_line += f"{total_v2/count:>3.0f}% {total_notes:>6} {total_errors:>5}"
    print(avg_line)
    print(f"  ({count} pieces)")

if big_diff:
    print(f"\nPieces with >10% SER difference (v1 vs v2): {len(big_diff)}")
    for pid, v1, v2 in sorted(big_diff, key=lambda x: abs(x[1] - x[2]), reverse=True):
        print(f"  {pid}: v1={v1}% -> v2={v2}% (delta={v2-v1:+d}%)")
