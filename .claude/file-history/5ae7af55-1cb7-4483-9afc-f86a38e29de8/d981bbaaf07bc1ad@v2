#!/usr/bin/env python3
"""Re-diagnose an existing eval run using v2 methodology.

Takes a run directory that has output MusicXML files and re-runs
diagnosis with the v2 flat-sequence comparison. Writes updated
results.json and summary.md in v2 format.

Usage:
    python scripts/rediagnose_run.py runs/main/f0c0df3_avg48
    python scripts/rediagnose_run.py runs/main/f0c0df3_avg48 --dry-run
"""

import argparse
import json
import sys
from collections import defaultdict
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
DATA_DIR = SCRIPT_DIR.parent

sys.path.insert(0, str(SCRIPT_DIR))
from run_evaluation import diagnose_piece, _write_summary, STRUCTURAL_METRICS


def rediagnose_run(run_dir: Path, dry_run: bool = False) -> dict:
    """Re-diagnose all pieces in a run directory."""
    manifest = json.load(open(DATA_DIR / "manifest.json"))

    # Load existing results for metadata
    old_results_path = run_dir / "results.json"
    old_results = {}
    if old_results_path.exists():
        with open(old_results_path) as f:
            old_results = json.load(f)

    # Find piece directories
    piece_dirs = sorted(
        d for d in run_dir.iterdir()
        if d.is_dir() and d.name.startswith("piece-")
    )

    if not piece_dirs:
        print(f"No piece directories found in {run_dir}", file=sys.stderr)
        return {}

    piece_results: dict[str, dict] = {}
    overall_note_errors = 0
    overall_note_total = 0
    overall_perfect = 0
    overall_measures = 0
    overall_note_breakdown: dict[str, int] = defaultdict(int)
    overall_structural: dict[str, dict[str, int]] = defaultdict(lambda: {"errors": 0, "total": 0})

    for piece_dir in piece_dirs:
        piece_id = piece_dir.name
        gt_path = DATA_DIR / "sources" / f"{piece_id}.xml"
        if not gt_path.exists():
            print(f"  SKIP {piece_id}: no ground truth")
            continue

        out_files = sorted(piece_dir.glob("*.musicxml"))
        if not out_files:
            print(f"  SKIP {piece_id}: no output files")
            continue

        info = manifest.get(piece_id, {})
        result = diagnose_piece(gt_path, out_files)
        if result is None:
            print(f"  SKIP {piece_id}: diagnosis failed")
            continue

        diag, per_page = result
        ser = diag.note_ser.pct

        per_staff_ser = {
            str(s): m.pct for s, m in diag.note_ser_by_staff.items()
        }

        note_error_counts: dict[str, int] = defaultdict(int)
        for e in diag.note_errors:
            if e.sub_category:
                note_error_counts[e.sub_category] += 1
            else:
                note_error_counts[e.category] += 1

        structural = {}
        structural_attrs = [
            diag.key_accuracy, diag.time_accuracy, diag.clef_accuracy,
            diag.tie_accuracy, diag.slur_accuracy, diag.grace_accuracy,
            diag.articulation_accuracy, diag.repeat_accuracy,
        ]
        for metric in structural_attrs:
            if metric.total > 0 or metric.errors > 0:
                structural[metric.name] = {
                    "errors": metric.errors,
                    "total": metric.total,
                    "rate": metric.pct,
                }

        piece_data = {
            "name": info.get("name", piece_id),
            "ser": ser,
            "note_errors": diag.note_ser.errors,
            "note_total": diag.note_ser.total,
            "per_staff_ser": per_staff_ser,
            "note_error_breakdown": {k: v for k, v in note_error_counts.items() if v > 0},
            "structural": structural,
            "perfect_measures": diag.perfect_measures,
            "total_measures": diag.total_measures_compared,
            "measure_count_gt": diag.measure_count_gt,
            "measure_count_out": diag.measure_count_out,
            "per_page": per_page,
        }

        print(f"  {piece_id}: SER {ser}% ({diag.note_ser.errors}/{diag.note_ser.total})")

        piece_results[piece_id] = piece_data
        overall_perfect += piece_data["perfect_measures"]
        overall_measures += piece_data["total_measures"]
        overall_note_errors += piece_data["note_errors"]
        overall_note_total += piece_data["note_total"]
        for cat, cnt in piece_data.get("note_error_breakdown", {}).items():
            overall_note_breakdown[cat] += cnt
        for name, sdata in piece_data.get("structural", {}).items():
            overall_structural[name]["errors"] += sdata["errors"]
            overall_structural[name]["total"] += sdata["total"]

        if not dry_run:
            diag_path = piece_dir / "diagnosis.json"
            with open(diag_path, "w") as f:
                json.dump(piece_data, f, indent=2)

    if not piece_results:
        print("No pieces processed.", file=sys.stderr)
        return {}

    avg_ser = round(sum(p["ser"] for p in piece_results.values()) / len(piece_results))
    overall_ser = round(100 * overall_note_errors / max(overall_note_total, 1))

    structural_summary = {}
    for name, sdata in overall_structural.items():
        rate = round(100 * sdata["errors"] / max(sdata["total"], 1))
        structural_summary[name] = {
            "errors": sdata["errors"],
            "total": sdata["total"],
            "rate": rate,
        }

    results = {
        "timestamp": old_results.get("timestamp", "unknown"),
        "effort": old_results.get("effort", "unknown"),
        "git_commit": old_results.get("git_commit", "unknown"),
        "git_branch": old_results.get("git_branch", "unknown"),
        "homr_dir": old_results.get("homr_dir", "unknown"),
        "eval_version": "v2",
        "overall": {
            "pieces": len(piece_results),
            "avg_ser": avg_ser,
            "overall_ser": overall_ser,
            "note_errors": overall_note_errors,
            "note_total": overall_note_total,
            "perfect_measures_pct": (
                round(100 * overall_perfect / overall_measures)
                if overall_measures > 0 else 0
            ),
            "perfect_measures": overall_perfect,
            "total_measures": overall_measures,
            "note_error_breakdown": {k: v for k, v in overall_note_breakdown.items() if v > 0},
            "structural": structural_summary,
        },
        "pieces": piece_results,
    }

    if not dry_run:
        results_path = run_dir / "results.json"
        with open(results_path, "w") as f:
            json.dump(results, f, indent=2)
        _write_summary(run_dir, results)
        print(f"\nWrote {results_path}")
        print(f"Wrote {run_dir / 'summary.md'}")

    print(f"\n{len(piece_results)} pieces, avg SER {avg_ser}% (overall {overall_ser}%)")
    print(f"{overall_note_errors:,} note errors / {overall_note_total:,} notes")
    print(f"{overall_perfect}/{overall_measures} perfect measures")

    if structural_summary:
        print("\nStructural accuracy:")
        for name in sorted(structural_summary):
            s = structural_summary[name]
            acc = 100 - s["rate"]
            print(f"  {name:<20} {s['errors']:>5}/{s['total']:<5} ({acc}% accuracy)")

    return results


def main() -> None:
    parser = argparse.ArgumentParser(description="Re-diagnose a run with v2 methodology")
    parser.add_argument("run_dir", type=str, help="Path to run directory")
    parser.add_argument("--dry-run", action="store_true", help="Don't write files")
    args = parser.parse_args()

    run_dir = Path(args.run_dir).resolve()
    if not run_dir.is_dir():
        print(f"ERROR: {run_dir} is not a directory", file=sys.stderr)
        sys.exit(1)

    rediagnose_run(run_dir, dry_run=args.dry_run)


if __name__ == "__main__":
    main()
